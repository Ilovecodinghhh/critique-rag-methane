# Environment variables for the Critique-Oriented RAG
# Copy this to .env and fill in your values

# ---------------------------------------------------------------------------
# LLM Provider Selection
# ---------------------------------------------------------------------------
# Choose your LLM provider: anthropic, openai, gemini, deepseek, kimi, minimax, glm
LLM_PROVIDER=anthropic

# Optional: Override the default model for your chosen provider
# REVIEWER_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Provider API Keys (set the one matching your LLM_PROVIDER)
# ---------------------------------------------------------------------------

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (ChatGPT)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
# GEMINI_API_KEY=your-api-key-here
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# DeepSeek
# DEEPSEEK_API_KEY=your-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi (Moonshot AI)
# KIMI_API_KEY=your-api-key-here
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# MiniMax
# MINIMAX_API_KEY=your-api-key-here
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# GLM (Zhipu AI / ChatGLM)
# GLM_API_KEY=your-api-key-here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---------------------------------------------------------------------------
# Optional Settings
# ---------------------------------------------------------------------------

# GitHub token for cloning private paper repos
# GITHUB_TOKEN=ghp_your_token_here
